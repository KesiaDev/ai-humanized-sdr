# ============================================================
# SDR IA Humanizada — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# URL do backend da plataforma SDR IA
# Em desenvolvimento: http://localhost:3001
# Em produção: https://seudominio.com
VITE_API_BASE_URL=http://localhost:3001

# URL do webhook N8N para disparar workflows
# Encontre em: N8N → Workflow → Webhook node → Production URL
VITE_N8N_WEBHOOK_URL=https://n8n-railway-production-f85d.up.railway.app/webhook/6135315d-54ad-4fc7-9310-5cb1b88a987b

# ============================================================
# ATENÇÃO: As variáveis abaixo são apenas para o BACKEND
# Nunca exponha tokens Z-API no frontend (sem prefixo VITE_)
# ============================================================

# Z-API — WhatsApp Business
# Encontre em: app.z-api.io → Instâncias → sua instância
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# OpenAI — para geração de respostas humanizadas no N8N
OPENAI_API_KEY=

# URL base do backend (usada pelo N8N para callbacks)
BACKEND_API_URL=http://localhost:3001
