# Porta do servidor (Railway usa PORT automaticamente)
PORT=3001

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# ── Segurança (OWASP A01/A06/A08) ─────────────────────────
# Chave de API interna — frontend envia como Authorization: Bearer <key>
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deixe vazio em desenvolvimento local para desativar a proteção
INTERNAL_API_KEY=

# Secret do webhook Z-API — configure também no painel Z-API
# Gere com: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ZAPI_WEBHOOK_SECRET=

# ── Z-API — WhatsApp Business ──────────────────────────────
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── N8N — Webhook de disparo ───────────────────────────────
N8N_WEBHOOK_URL=https://n8n-railway-production-f85d.up.railway.app/webhook/6135315d-54ad-4fc7-9310-5cb1b88a987b

# ── OpenAI (se o backend precisar chamar diretamente) ──────
OPENAI_API_KEY=
